#!/usr/bin/env node
// Mock claude CLI for testing.
// Echoes "MOCK_RESPONSE" to stdout (simulating --print mode).
// If the prompt contains "ERROR", exits with code 1 and writes to stderr.
// If the prompt contains "STREAM", writes two chunks with a small delay.

const args = process.argv.slice(2);
const prompt = args[args.length - 1] || '';

if (prompt.includes('AUTH_FAIL')) {
  process.stderr.write('not logged in\n');
  process.exit(1);
}

if (prompt.includes('RATE_LIMIT')) {
  process.stderr.write('rate limit exceeded\n');
  process.exit(1);
}

if (prompt.includes('EXIT_ERROR')) {
  process.stderr.write('something went wrong\n');
  process.exit(1);
}

if (prompt.includes('MULTI_CHUNK')) {
  process.stdout.write('chunk1');
  setTimeout(() => {
    process.stdout.write('chunk2');
    process.exit(0);
  }, 50);
} else {
  process.stdout.write('MOCK_RESPONSE');
  process.exit(0);
}
